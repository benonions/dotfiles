# Global Codex rules baseline.
# Control-first for irreversible actions, low friction for read/edit loops.

# 0) Shell wrappers: prompt.
prefix_rule(pattern=["bash", "-lc"], decision="prompt")
prefix_rule(pattern=["bash", "-c"], decision="prompt")
prefix_rule(pattern=["/bin/bash", "-lc"], decision="prompt")
prefix_rule(pattern=["/bin/bash", "-c"], decision="prompt")
prefix_rule(pattern=["zsh", "-lc"], decision="prompt")
prefix_rule(pattern=["zsh", "-c"], decision="prompt")
prefix_rule(pattern=["/bin/zsh", "-lc"], decision="prompt")
prefix_rule(pattern=["/bin/zsh", "-c"], decision="prompt")
prefix_rule(pattern=["sh", "-c"], decision="prompt")
prefix_rule(pattern=["/bin/sh", "-c"], decision="prompt")

# 1) Git reads + staging: allow.
prefix_rule(pattern=["git", "status"], decision="allow")
prefix_rule(pattern=["git", "diff"], decision="allow")
prefix_rule(pattern=["git", "log"], decision="allow")
prefix_rule(pattern=["git", "show"], decision="allow")
prefix_rule(pattern=["git", "blame"], decision="allow")
prefix_rule(pattern=["git", "branch"], decision="allow")
prefix_rule(pattern=["git", "rev-parse"], decision="allow")
prefix_rule(pattern=["git", "symbolic-ref"], decision="allow")
prefix_rule(pattern=["git", "add"], decision="allow")
prefix_rule(pattern=["git", "restore", "--staged"], decision="allow")

# 2) Git hard gates.
prefix_rule(pattern=["git", "commit"], decision="forbidden")
prefix_rule(pattern=["git", "push"], decision="forbidden")

# 3) Git history mutation: prompt.
prefix_rule(pattern=["git", "merge"], decision="prompt")
prefix_rule(pattern=["git", "rebase"], decision="prompt")
prefix_rule(pattern=["git", "reset"], decision="prompt")
prefix_rule(pattern=["git", "cherry-pick"], decision="prompt")
prefix_rule(pattern=["git", "revert"], decision="prompt")
prefix_rule(pattern=["git", "tag"], decision="prompt")
prefix_rule(pattern=["git", "branch", "-m"], decision="prompt")
prefix_rule(pattern=["git", "branch", "-M"], decision="prompt")
prefix_rule(pattern=["git", "branch", "-d"], decision="prompt")
prefix_rule(pattern=["git", "branch", "-D"], decision="prompt")
prefix_rule(pattern=["git", "branch", "-f"], decision="prompt")

# 4) Remote reads: allow.
prefix_rule(pattern=["acli", "jira", "workitem", "search"], decision="allow")
prefix_rule(pattern=["acli", "jira", "workitem", "view"], decision="allow")
prefix_rule(pattern=["acli", "jira", "workitem", "comment", "list"], decision="allow")
prefix_rule(pattern=["gh", "pr", "view"], decision="allow")
prefix_rule(pattern=["gh", "pr", "list"], decision="allow")
prefix_rule(pattern=["gh", "pr", "diff"], decision="allow")
prefix_rule(pattern=["gh", "issue", "view"], decision="allow")
prefix_rule(pattern=["gh", "issue", "list"], decision="allow")
prefix_rule(pattern=["kubectl", "get"], decision="allow")
prefix_rule(pattern=["kubectl", "describe"], decision="allow")
prefix_rule(pattern=["kubectl", "logs"], decision="allow")
prefix_rule(pattern=["kubectl", "top"], decision="allow")
prefix_rule(pattern=["kubectl", "events"], decision="allow")
prefix_rule(pattern=["kubectl", "api-resources"], decision="allow")
prefix_rule(pattern=["kubectl", "api-versions"], decision="allow")
prefix_rule(pattern=["kubectl", "explain"], decision="allow")
prefix_rule(pattern=["kubectl", "version"], decision="allow")
prefix_rule(pattern=["terraform", "plan"], decision="allow")
prefix_rule(pattern=["terraform", "show"], decision="allow")
prefix_rule(pattern=["terraform", "output"], decision="allow")
prefix_rule(pattern=["terraform", "validate"], decision="allow")
prefix_rule(pattern=["terraform", "fmt"], decision="allow")
prefix_rule(pattern=["terraform", "version"], decision="allow")
prefix_rule(pattern=["curl"], decision="allow")

# 5) Remote writes: prompt.
prefix_rule(pattern=["acli", "jira", "workitem", "create"], decision="prompt")
prefix_rule(pattern=["acli", "jira", "workitem", "update"], decision="prompt")
prefix_rule(pattern=["acli", "jira", "workitem", "transition"], decision="prompt")
prefix_rule(pattern=["acli", "jira", "workitem", "comment", "add"], decision="prompt")
prefix_rule(pattern=["acli", "jira", "issue", "create"], decision="prompt")
prefix_rule(pattern=["acli", "jira", "issue", "update"], decision="prompt")
prefix_rule(pattern=["acli", "jira", "issue", "transition"], decision="prompt")
prefix_rule(pattern=["gh", "pr", "merge"], decision="prompt")
prefix_rule(pattern=["gh", "api"], decision="prompt")
prefix_rule(pattern=["curl", "-X", "POST"], decision="prompt")
prefix_rule(pattern=["curl", "-X", "PUT"], decision="prompt")
prefix_rule(pattern=["curl", "-X", "PATCH"], decision="prompt")
prefix_rule(pattern=["curl", "-X", "DELETE"], decision="prompt")
prefix_rule(pattern=["curl", "--request", "POST"], decision="prompt")
prefix_rule(pattern=["curl", "--request", "PUT"], decision="prompt")
prefix_rule(pattern=["curl", "--request", "PATCH"], decision="prompt")
prefix_rule(pattern=["curl", "--request", "DELETE"], decision="prompt")
prefix_rule(pattern=["curl", "-d"], decision="prompt")
prefix_rule(pattern=["curl", "--data"], decision="prompt")
prefix_rule(pattern=["curl", "--data-raw"], decision="prompt")
prefix_rule(pattern=["curl", "--data-binary"], decision="prompt")
prefix_rule(pattern=["curl", "-F"], decision="prompt")
prefix_rule(pattern=["curl", "--form"], decision="prompt")
prefix_rule(pattern=["kubectl", "apply"], decision="prompt")
prefix_rule(pattern=["kubectl", "patch"], decision="prompt")
prefix_rule(pattern=["kubectl", "delete"], decision="prompt")
prefix_rule(pattern=["kubectl", "create"], decision="prompt")
prefix_rule(pattern=["kubectl", "replace"], decision="prompt")
prefix_rule(pattern=["kubectl", "scale"], decision="prompt")
prefix_rule(pattern=["kubectl", "annotate"], decision="prompt")
prefix_rule(pattern=["kubectl", "label"], decision="prompt")
prefix_rule(pattern=["kubectl", "rollout"], decision="prompt")
prefix_rule(pattern=["terraform", "apply"], decision="prompt")
prefix_rule(pattern=["terraform", "destroy"], decision="prompt")
prefix_rule(pattern=["terraform", "import"], decision="prompt")
prefix_rule(pattern=["terraform", "taint"], decision="prompt")
prefix_rule(pattern=["terraform", "untaint"], decision="prompt")
prefix_rule(pattern=["terraform", "state"], decision="prompt")
prefix_rule(pattern=["psql"], decision="prompt")
prefix_rule(pattern=["mysql"], decision="prompt")
prefix_rule(pattern=["mongosh"], decision="prompt")

# 6) Local destructive actions: prompt.
prefix_rule(pattern=["rm", "-rf"], decision="prompt")
prefix_rule(pattern=["rm", "-fr"], decision="prompt")
prefix_rule(pattern=["rm", "-r"], decision="prompt")
prefix_rule(pattern=["chmod", "-R"], decision="prompt")
prefix_rule(pattern=["chown", "-R"], decision="prompt")
prefix_rule(pattern=["git", "clean"], decision="prompt")
prefix_rule(pattern=["sudo"], decision="prompt")

# 7) Read-first local utilities: allow.
prefix_rule(pattern=["cat"], decision="allow")
prefix_rule(pattern=["rg"], decision="allow")
prefix_rule(pattern=["ls"], decision="allow")
prefix_rule(pattern=["find"], decision="allow")
prefix_rule(pattern=["sed"], decision="allow")
prefix_rule(pattern=["awk"], decision="allow")
prefix_rule(pattern=["jq"], decision="allow")
prefix_rule(pattern=["head"], decision="allow")
prefix_rule(pattern=["tail"], decision="allow")
prefix_rule(pattern=["wc"], decision="allow")
prefix_rule(pattern=["xargs"], decision="allow")
prefix_rule(pattern=["emacsclient", "--eval"], decision="allow")
