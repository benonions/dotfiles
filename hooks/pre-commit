#!/usr/bin/env bash
# Pre-commit hook: scan staged files for secrets and security issues

# 1. Gitleaks: detect hardcoded secrets
if command -v gitleaks &>/dev/null; then
  gitleaks protect --staged --verbose || exit 1
else
  echo "gitleaks not found, skipping secrets scan"
fi

# 2. Semgrep: security + best-practice lint on staged files
if command -v semgrep &>/dev/null; then
  STAGED_FILES=$(git diff --cached --name-only --diff-filter=d)
  if [ -n "$STAGED_FILES" ]; then
    echo "Running semgrep on staged files..."
    # shellcheck disable=SC2086
    semgrep scan --quiet --config auto --error $STAGED_FILES || exit 1
  fi
else
  echo "semgrep not found, skipping security lint"
fi
